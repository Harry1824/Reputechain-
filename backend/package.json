{
  "name": "reputechain-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "ReputeChain backend API",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "concurrently \"npm run ganache\" \"node scripts/bootstrap.js && ts-node-dev --respawn --transpile-only src/server.ts\"",
    "ganache": "ganache --db ./chain_data --wallet.accounts=\"0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80,1000000000000000000000\" -p 8545",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.3",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-ui-express": "^4.1.6",
    "concurrently": "^9.2.1",
    "form-data": "^4.0.0",
    "ganache": "^7.9.2",
    "hardhat": "^3.2.0",
    "jest": "^29.7.0",
    "solc": "^0.8.34",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
